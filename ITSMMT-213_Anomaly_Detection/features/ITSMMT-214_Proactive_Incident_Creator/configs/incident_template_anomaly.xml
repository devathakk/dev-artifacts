    <description>Template applied to proactively created incidents from the Anomaly Detection system.</description>
    <template>priority=2^impact=1^urgency=2^category=software^subcategory=performance^assignment_group=IT Operations^u_proactive_alert=true</template>
    <sys_scope display_value="Global">global</sys_scope>
  </sys_template>
</record_update>
